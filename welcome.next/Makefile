####### Compile

main.o: main.cpp Welcome.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o main.cpp

Welcome.o: Welcome.cpp Welcome.h \
		ui_Welcome.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o Welcome.o Welcome.cpp

qrc_ImgsResources.o: qrc_ImgsResources.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o qrc_ImgsResources.o qrc_ImgsResources.cpp

qrc_scripts.o: qrc_scripts.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o qrc_scripts.o qrc_scripts.cpp

moc_Welcome.o: moc_Welcome.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_Welcome.o moc_Welcome.cpp

####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/welcome-next/bin || mkdir -p $(INSTALL_ROOT)/opt/welcome-next/bin
	$(QINSTALL_PROGRAM) $(QMAKE_TARGET) $(INSTALL_ROOT)/opt/welcome-next/bin/$(QMAKE_TARGET)
	-$(STRIP) $(INSTALL_ROOT)/opt/welcome-next/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/welcome-next/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/welcome-next/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

